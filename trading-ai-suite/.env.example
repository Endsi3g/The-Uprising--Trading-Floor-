# ═══════════════════════════════════════════════
# Trading AI Suite — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── System ─────────────────────────────────
ENV=development # development | staging | production - REMEMBER TO SET CORRECTLY
HB_PASSWORD=replace_with_secure_password

# ─── Exchange API Keys (READ + TRADE ONLY) ──
# ⚠  DO NOT ENABLE WITHDRAWALS
BINANCE_API_KEY=
BINANCE_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── AI & NLP Services ─────────────────────
# "http://ollama:11434" only works inside Docker Compose.
# If running locally, use "http://localhost:11434" instead.
OLLAMA_HOST=http://ollama:11434
NEWS_API_KEY=
MARKETAUX_API_KEY=

# ─── Risk Engine ────────────────────────────
INITIAL_CAPITAL=<YOUR_INITIAL_CAPITAL> # e.g., 100 or 1000

# ─── Alert Hub (Discord / Telegram) ────────
DISCORD_WEBHOOK_URL=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Dashboard (Public Environment Variables) ───
# For browser-side calls, these MUST be externally reachable (e.g. localhost or your IP).
# For server-side (Node.js/Electron) inter-service calls, Docker service names can be used.
NEXT_PUBLIC_BROKER_HUB_URL=http://broker-hub:8001
NEXT_PUBLIC_NEWS_HUB_URL=http://news-hub:8002
NEXT_PUBLIC_AI_SERVICE_URL=http://ai-service:8003
NEXT_PUBLIC_RISK_ENGINE_URL=http://risk-engine:8004
