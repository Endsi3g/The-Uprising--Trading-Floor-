# ═══════════════════════════════════════════════
# Trading AI Suite — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Hummingbot ─────────────────────────────
HB_PASSWORD=replace_with_secure_password

# ─── Exchange API Keys (READ + TRADE ONLY) ──
# ⚠  DO NOT ENABLE WITHDRAWALS
BINANCE_API_KEY=
BINANCE_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── AI & NLP Services ─────────────────────
OLLAMA_HOST=http://ollama:11434
NEWS_API_KEY=
MARKETAUX_API_KEY=

# ─── Risk Engine ────────────────────────────
INITIAL_CAPITAL=500.0

# ─── Alert Hub (Discord / Telegram) ────────
DISCORD_WEBHOOK_URL=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Dashboard (Next.js public env vars) ───
NEXT_PUBLIC_BROKER_HUB_URL=http://localhost:8001
NEXT_PUBLIC_NEWS_HUB_URL=http://localhost:8002
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8003
NEXT_PUBLIC_RISK_ENGINE_URL=http://localhost:8004
