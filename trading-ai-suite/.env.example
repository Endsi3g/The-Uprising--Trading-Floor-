# ============================================
# THE UPRISING TRADING FLOOR
# Production Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Environment Mode ---
ENV=production

# --- Exchange API Keys (at least one required) ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

KUCOIN_API_KEY=your_kucoin_api_key
KUCOIN_API_SECRET=your_kucoin_api_secret
KUCOIN_PASSPHRASE=your_kucoin_passphrase

BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# --- AI Engine (Ollama) ---
OLLAMA_URL=http://ollama:11434

# --- Alert Broadcasting ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Risk Management ---
INITIAL_CAPITAL=10000
MAX_DAILY_LOSS_PCT=0.05
MAX_TRADE_LOSS_PCT=0.02
CIRCUIT_BREAKER_PCT=0.10

# --- Dashboard (Next.js) ---
NEXT_PUBLIC_BROKER_HUB_URL=http://localhost:8001
NEXT_PUBLIC_NEWS_HUB_URL=http://localhost:8002
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8003
NEXT_PUBLIC_RISK_ENGINE_URL=http://localhost:8004
